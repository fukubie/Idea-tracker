# Appwrite - get these from your project at https://cloud.appwrite.io
# One value per line (the ID only, not the name). No commas, no extra values.
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=
VITE_APPWRITE_DATABASE_ID=
VITE_APPWRITE_COLLECTION_ID=
VITE_APPWRITE_STORAGE_BUCKET_ID=
# Optional: for AI idea expansion (create function in Appwrite, add GEMINI_API_KEY secret, paste code from appwrite-functions/idea-expand-gemini.js)
VITE_APPWRITE_FUNCTION_ID=

# Set to true to skip email verification screen (use if verification emails don't arrive or you disabled them in Appwrite)
VITE_SKIP_EMAIL_VERIFICATION=

VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_SECRET=

VITE_GITHUB_CLIENT_ID=
VITE_GITHUB_CLIENT_SECRET=

VITE_DISCORD_CLIENT_ID=
VITE_DISCORD_CLIENT_SECRET=

