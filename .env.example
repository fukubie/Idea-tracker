# Appwrite - get these from your project at https://cloud.appwrite.io
# One value per line (the ID only, not the name). No commas, no extra values.
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=
VITE_APPWRITE_DATABASE_ID=
VITE_APPWRITE_COLLECTION_ID=
VITE_APPWRITE_STORAGE_BUCKET_ID=
# Optional: for AI idea expansion (create function in Appwrite, add GEMINI_API_KEY secret in Appwrite, paste code from appwrite-functions/idea-expand-gemini.js)
VITE_APPWRITE_FUNCTION_ID=

# Optional: for AI pitch generation (separate Appwrite function that returns { success, pitch })
VITE_APPWRITE_PITCH_FUNCTION_ID=

# Set to true to skip email verification screen (NOT recommended for production)
VITE_SKIP_EMAIL_VERIFICATION=false

VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_SECRET=

VITE_GITHUB_CLIENT_ID=
VITE_GITHUB_CLIENT_SECRET=

VITE_DISCORD_CLIENT_ID=
VITE_DISCORD_CLIENT_SECRET=

# Optional: keys used at build-time only (do NOT expose these from Appwrite; keep them in your deployment provider as server-side env vars)
GOOGLE_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
LINGODOTDEV_API_KEY=

# Optional: browser-exposed Google API key (for client-side usage where needed)
VITE_GOOGLE_API_KEY=

# Optional: private messages collection (for secure user-to-user messaging)
VITE_APPWRITE_MESSAGES_COLLECTION_ID=

